# Local development example only.
# Do not reuse these values in production.
# Public frontend origin used for QR/public attendance links.
# In production, this must match apps/backend FRONTEND_URL exactly.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public backend API base URL used by the frontend server routes.
# In production, this must be a real public API URL and must not use localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
