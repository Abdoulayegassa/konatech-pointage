# Local development example only.
# Do not reuse these values in production.
PORT=4000
# Public frontend origin used by CORS and the backend attendance-entry redirect.
# In production, this must match apps/frontend NEXT_PUBLIC_APP_URL exactly.
FRONTEND_URL=http://localhost:3000
JWT_SECRET=konatech-local-jwt-secret-change-this-value-1234
JWT_EXPIRES_IN=1d
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/konatech_attendance?schema=public
JSON_BODY_LIMIT=10mb
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_TTL_MS=60000
LOGIN_RATE_LIMIT_MAX=20
TRUST_PROXY_HOPS=0
ATTENDANCE_SECURITY_ENABLED=false
# COMPANY_LATITUDE=5.359952
# COMPANY_LONGITUDE=-4.008256
# Employee self check-in/check-out uses GPS-only geofencing when enabled.
ATTENDANCE_TRUSTED_RADIUS_METERS=100
ATTENDANCE_WARNING_RADIUS_METERS=300
# Optional legacy Cloudinary configuration for historical photo evidence paths.
# Normal GPS-only attendance does not require these values.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_ATTENDANCE_FOLDER=konatech/attendance-verifications
CLOUDINARY_UPLOAD_TIMEOUT_MS=10000
CLOUDINARY_UPLOAD_MAX_RETRIES=2
CLOUDINARY_UPLOAD_RETRY_DELAY_MS=300
