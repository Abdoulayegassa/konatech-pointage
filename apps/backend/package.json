{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build",
    "start": "node dist/main.js",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit --incremental false -p tsconfig.json",
    "test": "node ./node_modules/jest/bin/jest.js --runInBand --config ./test/jest-e2e.json",
    "pins:backfill": "node -r ts-node/register ./scripts/backfill-employee-pin-code-hashes.ts",
    "snapshots:backfill": "node -r ts-node/register ./scripts/backfill-attendance-schedule-snapshots.ts",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "prisma:seed": "node ./node_modules/prisma/build/index.js db seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "puppeteer": "^24.43.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
