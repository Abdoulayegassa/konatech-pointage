# Docker Compose production example.
# Copy this file to .env.production and replace every placeholder before deploy.

POSTGRES_DB=konatech_attendance
POSTGRES_USER=konatech_app
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_PORT=5433

BACKEND_PORT=4000
FRONTEND_PORT=3000

FRONTEND_URL=https://attendance.example.com
NEXT_PUBLIC_APP_URL=https://attendance.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
API_BASE_URL=https://api.example.com/api/v1

JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRES_IN=1d
TRUST_PROXY_HOPS=1

JSON_BODY_LIMIT=10mb
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_TTL_MS=60000
LOGIN_RATE_LIMIT_MAX=20

ATTENDANCE_SECURITY_ENABLED=false
# COMPANY_LATITUDE=5.359952
# COMPANY_LONGITUDE=-4.008256
ATTENDANCE_TRUSTED_RADIUS_METERS=100
ATTENDANCE_WARNING_RADIUS_METERS=300
ATTENDANCE_MAX_ACCURACY_METERS=200
# ATTENDANCE_ALLOWED_RADIUS_METERS=300
ATTENDANCE_PDF_RENDERER=puppeteer

# Optional legacy Cloudinary variables for historical photo evidence only.
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_ATTENDANCE_FOLDER=konatech/attendance-verifications
CLOUDINARY_UPLOAD_TIMEOUT_MS=10000
CLOUDINARY_UPLOAD_MAX_RETRIES=2
CLOUDINARY_UPLOAD_RETRY_DELAY_MS=300
